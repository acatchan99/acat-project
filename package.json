{
  "name": "acat-fag",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite --host",
    "dev:api": "npm run dev --prefix server",
    "build": "npm run build:web",
    "build:web": "npm run optimize-images && vite build",
    "optimize-images": "node scripts/optimize-images.mjs",
    "postinstall": "npm install --prefix server",
    "start": "cross-env NODE_ENV=production npm run start --prefix server",
    "start:api": "cross-env NODE_ENV=production API_ONLY=true npm run start --prefix server",
    "seed": "npm run seed --prefix server",
    "preview": "vite preview --host"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "sharp": "^0.33.5",
    "vite": "^6.0.3"
  }
}
